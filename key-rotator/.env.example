# Copy this to .env and fill in your free-tier API keys.
# You can add multiple keys per provider by comma-separating them.
# Keys added here are loaded automatically on startup.
# You can also add/remove keys live via the dashboard at http://localhost:7860

PORT=7860

# Google Gemini  — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Groq           — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenRouter     — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Cohere         — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=...

# Mistral        — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...
